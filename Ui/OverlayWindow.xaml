<Window x:Class="ClaudeUsageMonitor.Ui.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Claude Usage"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True"
        ShowActivated="False"
        SnapsToDevicePixels="True"
        UseLayoutRounding="True"
        SizeToContent="Manual">

    <Border x:Name="RootPanel"
            CornerRadius="0"
            Background="Transparent"
            BorderThickness="0"
            Padding="4,3">
        <Grid>

        <!-- ===== STACKED (two rows) ===== -->
        <Grid x:Name="StackedRoot">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="4"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- 5h row -->
            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" x:Name="Tag5h" Text="5h" VerticalAlignment="Center"
                           FontFamily="Segoe UI" FontSize="9" FontWeight="Bold"
                           Foreground="#9A9A9A"/>

                <StackPanel Grid.Column="1" x:Name="Seg5h" Orientation="Horizontal"
                            VerticalAlignment="Center"/>

                <TextBlock Grid.Column="2" x:Name="Label5h" Margin="9,0,2,0"
                           VerticalAlignment="Center" Text="--%"
                           FontFamily="Segoe UI" FontSize="11" FontWeight="Bold"
                           Foreground="#ECECEC"/>
            </Grid>

            <!-- 7d row -->
            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" x:Name="Tag7d" Text="7d" VerticalAlignment="Center"
                           FontFamily="Segoe UI" FontSize="9" FontWeight="Bold"
                           Foreground="#9A9A9A"/>

                <StackPanel Grid.Column="1" x:Name="Seg7d" Orientation="Horizontal"
                            VerticalAlignment="Center"/>

                <TextBlock Grid.Column="2" x:Name="Label7d" Margin="9,0,2,0"
                           VerticalAlignment="Center" Text="--%"
                           FontFamily="Segoe UI" FontSize="11" FontWeight="Bold"
                           Foreground="#ECECEC"/>
            </Grid>
        </Grid>

        <!-- ===== INLINE (one row, larger) ===== -->
        <StackPanel x:Name="InlineRoot" Orientation="Horizontal"
                    Visibility="Collapsed"
                    HorizontalAlignment="Center" VerticalAlignment="Center">
            <TextBlock x:Name="Tag5hI" Text="5h" VerticalAlignment="Center" Margin="0,0,5,0"
                       FontFamily="Segoe UI" FontSize="11" FontWeight="Bold" Foreground="#9A9A9A"/>
            <StackPanel x:Name="Seg5hI" Orientation="Horizontal" VerticalAlignment="Center"/>
            <TextBlock x:Name="Label5hI" Margin="8,0,16,0" VerticalAlignment="Center" Text="--%"
                       FontFamily="Segoe UI" FontSize="14" FontWeight="Bold" Foreground="#ECECEC"/>
            <TextBlock x:Name="Tag7dI" Text="7d" VerticalAlignment="Center" Margin="0,0,5,0"
                       FontFamily="Segoe UI" FontSize="11" FontWeight="Bold" Foreground="#9A9A9A"/>
            <StackPanel x:Name="Seg7dI" Orientation="Horizontal" VerticalAlignment="Center"/>
            <TextBlock x:Name="Label7dI" Margin="8,0,0,0" VerticalAlignment="Center" Text="--%"
                       FontFamily="Segoe UI" FontSize="14" FontWeight="Bold" Foreground="#ECECEC"/>
        </StackPanel>

        <!-- Status overlay (errors) -->
        <TextBlock x:Name="StatusText"
                   Visibility="Collapsed"
                   TextWrapping="Wrap" TextAlignment="Center"
                   VerticalAlignment="Center" HorizontalAlignment="Center"
                   FontFamily="Segoe UI" FontSize="10"
                   Foreground="#FFB34D"/>
        </Grid>
    </Border>
</Window>
